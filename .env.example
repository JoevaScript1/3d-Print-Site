# Copy to .env and fill in with your Stripe keys
# STRIPE_SECRET_KEY is your Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# STRIPE_PUBLISHABLE_KEY is your Stripe publishable key (starts with pk_live_ or pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# STRIPE_WEBHOOK_SECRET is the webhook signing secret from Stripe (optional for local testing with Stripe CLI)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
