# Copy to .env and fill in with your real Stripe values
# STRIPE_SECRET_KEY is your Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# STRIPE_PUBLISHABLE_KEY is your Stripe publishable key (starts with pk_live_ or pk_test_)
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# STRIPE_WEBHOOK_SECRET is the webhook signing secret from Stripe
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# SITE_URL should be your live Netlify site URL, for example https://your-site.netlify.app
SITE_URL=https://your-site.netlify.app

# STRIPE_PRICE_IDS should be a JSON object mapping your product names to Stripe Price IDs
# Example:
# STRIPE_PRICE_IDS={"Penjamin Earrings":"price_123","Perfect 4 Pack of Axolotl and Otters":"price_456"}
STRIPE_PRICE_IDS={}
